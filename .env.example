PORT=5000

# Supabase — database/storage only (no Supabase Auth)
SUPABASE_URL=https://narmnxkgxohrcvpzonid.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_PUBLISHABLE_KEY=optional legacy, not used for auth
# SUPABASE_SERVICE_ROLE_KEY=legacy fallback for SUPABASE_SECRET_KEY

# Local JWT auth (required)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Google login (mobile idToken verification)
GOOGLE_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=

# Microsoft login + calendar (same Azure app; separate redirect URIs)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_AUTH_REDIRECT_URI=bookmybarberapp://auth
MICROSOFT_AUTH_CALLBACK_URI=http://localhost:5000/v1/auth/microsoft/callback
MOBILE_AUTH_REDIRECT=bookmybarberapp://auth-complete

# SafePay (backend only — https://safepay-docs.netlify.app/)
SAFEPAY_SECRET_KEY=sec_your_secret_key
SAFEPAY_MERCHANT_API_KEY=your_merchant_api_key
SAFEPAY_ENV=sandbox
SAFEPAY_WEBHOOK_SECRET=your_webhook_secret
SAFEPAY_REDIRECT_URL=http://localhost:5173/payment/complete
SAFEPAY_CANCEL_URL=http://localhost:5173/payment/cancel

CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# Optional: direct Postgres URL to run scripts/apply-migrations.mjs locally
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Google Calendar OAuth (barber — separate from login client)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/v1/calendar/google/callback

# Microsoft Calendar OAuth (barber)
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:5000/v1/calendar/microsoft/callback
MOBILE_CALENDAR_REDIRECT=bookmybarberapp://calendar-connected

# Gemini AI
GEMINI_API_KEY=
